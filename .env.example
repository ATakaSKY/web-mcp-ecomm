# Postgres (local Docker default matches docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webmcp_shop
# Neon on Vercel often sets DATABASE_POSTGRES_URL — see db/connectionUrl.ts

# Better Auth (required for /api/auth and sessions)
# openssl rand -base64 32
BETTER_AUTH_SECRET=

# App origin serving the SPA + API (no trailing slash)
# Local full stack: URL from `npx vercel dev`, often http://localhost:3000
# Production: https://your-project.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# Optional — extra CORS-style trusted origins, comma-separated
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# If the Vite dev server calls an API on another origin:
# VITE_API_BASE=http://localhost:3000

# Razorpay (India — UPI, cards, netbanking; optional for demo pending orders)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# Webhook secret from Dashboard → Webhooks (event: payment.captured → /api/webhooks/razorpay)
# RAZORPAY_WEBHOOK_SECRET=...

# Optional — catalog admin: PUT /api/admin/product with header x-admin-secret
# ADMIN_API_SECRET=
