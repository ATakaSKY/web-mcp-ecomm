{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/auth",
      "destination": "/api/auth-internal"
    },
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/auth-internal?p=$1"
    }
  ]
}
